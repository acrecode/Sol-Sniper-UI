# ── Solana / data providers ───────────────────────────────────────────────
SOLANA_RPC_URL=                 # Helius dedicated/staked endpoint, e.g. https://mainnet.helius-rpc.com/?api-key=...
SOLANA_WS_URL=                  # wss endpoint for logsSubscribe fallback
HELIUS_API_KEY=
YELLOWSTONE_GRPC_URL=           # optional; gRPC upgrade (milestone 10)
YELLOWSTONE_GRPC_TOKEN=
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# ── Wallet (NEVER commit a real key) ──────────────────────────────────────
# base58-encoded secret key of a DEDICATED throwaway bot wallet.
# Leave blank to load the signer at runtime via the UI instead.
WALLET_PRIVATE_KEY=

# ── Operating mode ────────────────────────────────────────────────────────
MODE=dry-run                    # dry-run | devnet | live
# Live mode is refused unless this is also set to "true".
CONFIRM_LIVE=false

# ── Local services ────────────────────────────────────────────────────────
DB_PATH=./data/sniper.db
API_PORT=8787
LOG_LEVEL=info                  # trace|debug|info|warn|error
LOG_PRETTY=true
